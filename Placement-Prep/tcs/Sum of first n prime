#include <bits/stdc++.h>
using namespace std;
bool isPrime(int n){
    if(n<2)
        return false;
    if(n==2)
        return true;
    if(n%2==0)
        return false;
        
    for(int i=3;i*i<=n;i+=2){
        if(n%i==0)
            return false;
    }
    return true;
}
int main(){
    int n;
    cin>>n;
    int sum = 0;
    
    int count = 0,i=2;
    while(count<n){
        if(isPrime(i)){
            sum+=i;
            count++;
        }
        i++;
    }
    cout<<sum;
}
