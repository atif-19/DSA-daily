#include<bits/stdc++.h>
using namespace std;
string remove_duplicates(string s){
    string ans;
    
    for(int i=0;i<s.size();i++){
        if(ans.empty() || ans[ans.size()-1]!=s[i])
            ans.push_back(s[i]);
    }
    return ans;
}
int main(){
    string s;
    getline(cin,s);
    cout<<remove_duplicates(s);
    
}
