#include <bits/stdc++.h>
using namespace std;
int main(){
    int N;
    cin>>N;
    vector<int>arr;
    for(int i=0;i<N;i++){
        int num;
        cin>>num;
        arr.push_back(num);
    }
    
    int low = 0 ,mid=0,high = N-1;
    while(mid<=high){
        if(arr[mid]==0){
            swap(arr[low],arr[mid]);
            low++;
            mid++;
        }
        else if(arr[mid]==1)
            mid++;
        else{
            swap(arr[mid],arr[high]);
            high--;
        }
    }
    
    for(int i=0;i<arr.size();i++){
        cout<<arr[i]<<" ";
    }
}
