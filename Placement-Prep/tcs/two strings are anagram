#include <bits/stdc++.h>
using namespace std;

int main(){
    string s1,s2;
    getline(cin,s1);
    getline(cin,s2);
    
    vector<int>count(26,0);
    for(int i=0;i<s1.size();i++)
    count[s1[i]-'a']++;
    
    for(int i=0;i<s2.size();i++)
    count[s2[i]-'a']--;
    
    
    for(int i=0;i<26;i++){
        if(count[i]!=0){
            cout<<"false";
            return 0;
        }
    }
    cout<<"true";
    return 1;
    
}
