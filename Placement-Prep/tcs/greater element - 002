#include<bits/stdc++.h>
using namespace std;
int main(){
    vector<int>arr;
    int n;
    cin>>n;
    int maxi = INT_MIN;
    int ans = 0;
    for(int i=0;i<n;i++){
        int num;
        cin>>num;
        if(num>maxi)
        {
            maxi = num;
            ans++;
        }
        arr.push_back(num);
    }
    cout<<ans;
}
