#include <bits/stdc++.h>
using namespace std;
int main(){
    string s;
    getline(cin,s);
    int num;
    stringstream ss(s);
    vector<int>arr;
    while(ss>>num){
        arr.push_back(num);
    }
    
    unordered_map<int,int>mp;
    for(int i=0;i<arr.size();i++){
        mp[arr[i]]++;
    }
    
    for(int i=0;i<arr.size();i++)
    {
        if(mp[arr[i]]>1){
            mp[arr[i]]=1;
            cout<<arr[i]<<" ";
        }
    }
    return 0;
}
