#include<bits/stdc++.h>
using namespace std;
int main(){
    int income;
    vector<string>category;
    unordered_map<string,int>mp;
    cin>>income;
    
    int total =0;
    while(1){
    int expense;
    string s;
    cin>>s;
    if(s=="done")
    break;
    cin>>expense;
    if(mp[s]==0){
            category.push_back(s);
        }
        total += expense;
        mp[s]+=expense;
    }
    
    cout<<income<<" ";
    cout<<total<<" ";
    cout<<income-total<<" "<<endl;
    for(int i=0;i<category.size();i++){
        cout<<category[i]<<"-"<<mp[category[i]]<<endl;
    }
    
}
