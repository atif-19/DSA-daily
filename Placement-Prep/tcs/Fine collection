#include<bits/stdc++.h>
using namespace std;
int main(){
    int N;
    cin>>N;
    vector<int>arr;
    for(int i=0;i<N;i++){
        int num;
        cin>>num;
        arr.push_back(num);
    }
    int D,fine;
    cin>>D>>fine;
    
    int count = 0;
    for(int i=0;i<N;i++){
        if(arr[i]%2 != D%2)
        count++;
    }
    int ans = fine*count;
    
    cout<<ans;
}
