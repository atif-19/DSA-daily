#include<bits/stdc++.h>
using namespace std;
int main(){
    int n;
    vector<char>B;
    cin>>n;
    
    for(int i=0;i<n;i++){
        char color;
        cin>>color;
        B.push_back(color);
    }
    
    unordered_map<char,int>mp;
    for(int i=0;i<B.size();i++){
        mp[B[i]]++;
    }
    
    for(int i=0;i<n;i++){
        if(mp[B[i]]%2!=0)
        {
            cout<<B[i]<<' ';
            return 0;
        }
    }
    cout<<"All are even";
    return 0;
    
    
}
