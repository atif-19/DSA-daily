#include<bits/stdc++.h>
using namespace std;
bool isPrime(int n){
    if(i<=1)
        return 0;
        for(int i=2;i*i<=n;i++){
            if(n%i==0)
                return 0;
        }
        return 1;
}
int main(){
    int n1,n2;
    cin>>n1>>n2;
    
    int count = 0,i=2,prime1=0,prime2=0;
    while(count<n2){
        if(isPrime(i))
            count++;
        
        if(count==n1 && prime1==0)
            prime1 = i;
        else if(count==n2 && prime2 == 0)
            prime2 = i;
            
        i++;
    }
    
    cout<<prime1*prime2-1<<" ";
    
}
