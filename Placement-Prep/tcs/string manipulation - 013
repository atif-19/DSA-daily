#include<bits/stdc++.h>
using namespace std;
int main(){
    string s;
    cin>>s;
    if(s=="")
    {
        cout<<"Invalid Input"<<endl;
        return 0;
    }
    
    char ans1='.',ans2='.';
    unordered_map<char,int>mp;
    for(int i=0;i<s.size();i++){
        mp[s[i]]++;
    }
    for(int i=0;i<s.size();i++){
        if(mp[s[i]]==1){
            ans1 = s[i];
            break;
        }
    }
    
    int maxi=1;
    for(int i=0;i<s.size();i++){
        if(mp[s[i]]>maxi){
            maxi = mp[s[i]];
            ans2 = s[i];
        }
    }
    if(ans1=='.')
    {
        cout<<"None"<<" ";
    }
    else
        cout<<ans1<<" ";
    if(ans2=='.'){
        cout<<"None"<<" ";
    }
    else
        cout<<ans2<<" ";
    

    
    return 0;
}
